generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model PushSubscription {
  id         String @id @default(cuid())
  endpoint   String @unique
  p256dh     String
  auth       String
  // Kullanıcı ayarları — bildirim gönderirken hangi vakitleri hesaplayacağımızı bilmek için
  latitude   Float
  longitude  Float
  timezone   Float
  city       String  @default("")
  method     String  @default("suleymaniye")
  asrMadhab  String  @default("standard")
  alarms     String  @default("{}") // JSON string
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
