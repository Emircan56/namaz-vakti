# ═══════════════════════════════════════════
# Süleymaniye Namaz Vakitleri - Environment Variables
# ═══════════════════════════════════════════
#
# Vercel'de bu dosyaya GEREK YOK!
# Tüm değişkenler Vercel dashboard'dan eklenir.
#
# ── VERİTABANI ──
# Vercel → Storage → Create Database → otomatik oluşur
DATABASE_URL=postgresql://...

# ── VAPID ANAHTARLARI (Push Bildirimler) ──
# Oluşturmak: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:prayer@suleymaniye.com
