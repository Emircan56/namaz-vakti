# ═══════════════════════════════════════════
# Süleymaniye Namaz Vakitleri - Environment Variables
# ═══════════════════════════════════════════

# ── VERİTABANI ──
# Yerel geliştirme (SQLite dosyası):
DATABASE_URL=file:./db/custom.db

# Turso (üretim/bulut):
# DATABASE_URL=libsql://sizin-db-adiniz.turso.co
# DATABASE_AUTH_TOKEN=eyJhbGciOiJ...

# ── VAPID ANAHTARLARI (Push Bildirimler) ──
# Web push bildirimleri için gerekli.
# Oluşturmak: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:prayer@suleymaniye.com
