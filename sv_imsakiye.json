ZW\">Zimbabwe</option></select>\n                    </div>\n                    <div class=\"col\" id=\"cityArea\">İl</div>\n                    <div class=\"col-2\">\n                        <select class=\"form-control\" id=\"ddlCity\"><option value=\"-1\">Seçiniz</option><option value=\"1\">ADANA</option><option value=\"2\">ADIYAMAN</option><option value=\"3\">AFYONKARAHİSAR</option><option value=\"68\">AKSARAY</option><option value=\"5\">AMASYA</option><option value=\"6\">ANKARA</option><option value=\"7\">ANTALYA</option><option value=\"75\">ARDAHAN</option><option value=\"8\">ARTVİN</option><option value=\"9\">AYDIN</option><option value=\"4\">AĞRI</option><option value=\"10\">BALIKESİR</option><option value=\"74\">BARTIN</option><option value=\"72\">BATMAN</option><option value=\"69\">BAYBURT</option><option value=\"14\">BOLU</option><option value=\"15\">BURDUR</option><option value=\"16\">BURSA</option><option value=\"11\">BİLECİK</option><option value=\"12\">BİNGÖL</option><option value=\"13\">BİTLİS</option><option value=\"17\">ÇANAKKALE</option><option value=\"18\">ÇANKIRI</option><option value=\"19\">ÇORUM</option><option value=\"20\">DENİZLİ</option><option value=\"81\">DÜZCE</option><option value=\"21\">DİYARBAKIR</option><option value=\"22\">EDİRNE</option><option value=\"23\">ELAZIĞ</option><option value=\"25\">ERZURUM</option><option value=\"24\">ERZİNCAN</option><option value=\"26\">ESKİŞEHİR</option><option value=\"27\">GAZİANTEP</option><option value=\"29\">GÜMÜŞHANE</option><option value=\"28\">GİRESUN</option><option value=\"30\">HAKKARİ</option><option value=\"31\">HATAY</option><option value=\"32\">ISPARTA</option><option value=\"76\">IĞDIR</option><option value=\"34\">İSTANBUL</option><option value=\"35\">İZMİR</option><option value=\"46\">KAHRAMANMARAŞ</option><option value=\"78\">KARABÜK</option><option value=\"70\">KARAMAN</option><option value=\"36\">KARS</option><option value=\"37\">KASTAMONU</option><option value=\"38\">KAYSERİ</option><option value=\"71\">KIRIKKALE</option><option value=\"39\">KIRKLARELİ</option><option value=\"40\">KIRŞEHİR</option><option value=\"41\">KOCAELİ</option><option value=\"42\">KONYA</option><option value=\"43\">KÜTAHYA</option><option value=\"79\">KİLİS</option><option value=\"44\">MALATYA</option><option value=\"45\">MANİSA</option><option value=\"47\">MARDİN</option><option value=\"33\">MERSİN(İÇEL)</option><option value=\"48\">MUĞLA</option><option value=\"49\">MUŞ</option><option value=\"50\">NEVŞEHİR</option><option value=\"51\">NİĞDE</option><option value=\"52\">ORDU</option><option value=\"80\">OSMANİYE</option><option value=\"53\">RİZE</option><option value=\"54\">SAKARYA</option><option value=\"55\">SAMSUN</option><option value=\"57\">SİNOP</option><option value=\"58\">SİVAS</option><option value=\"56\">SİİRT</option><option value=\"63\">ŞANLIURFA</option><option value=\"73\">ŞIRNAK</option><option value=\"59\">TEKİRDAĞ</option><option value=\"60\">TOKAT</option><option value=\"61\">TRABZON</option><option value=\"62\">TUNCELİ</option><option value=\"64\">UŞAK</option><option value=\"65\">VAN</option><option value=\"77\">YALOVA</option><option value=\"66\">YOZGAT</option><option value=\"67\">ZONGULDAK</option></select>\n                    </div>\n                    <div class=\"col\" id=\"districtArea\">İlçe</div>\n                    <div class=\"col-2\">\n                        <select class=\"form-control\" id=\"ddlDistrict\"></select>\n                    </div>\n                    <div class=\"col-2\">\n                        <button type=\"button\" class=\"btn btn-primary\" id=\"btnSearchLocation\" style=\"vertical-align: middle;\">\n                            <i class=\"fas fa-search-location fa-2x\"></i><span id=\"searchText\">İmsakiye Göster</span>\n                        </button>\n                    </div>\n                    <div class=\"col-2\">\n                        <a class=\"btn btn-success\" id=\"aImsakiye\" style=\"vertical-align: middle; display:none\" href=\"#\">\n                            <i class=\"fas fa-search-location fa-2x\"></i><span id=\"downloadText\">İmsakiye İndir</span>\n                        </a>\n                    </div>\n                </div>\n                <div class=\"row\">&nbsp;</div>\n            </div>\n            <div class=\"container-fluid\">\n                <div class=\"row\" id=\"divImsakiye\"></div>\n            </div>\n        </main>\n    </div>\n\n    <footer class=\"border-top footer text-muted\">\n        <div class=\"container\">\n            <div class=\"row mt-2\">\n                <div class=\"col-sm\">\n                    © 2026 - Süleymaniye Takvimi\n                </div>\n                <div class=\"col-sm d-flex justify-content-end\">\n                    <select id=\"ddlLanguage\" class=\"ddlLanguage\">\n                        <option value=\"tr\">Türkçe</option>\n                        <option value=\"en\">English</option>\n                        <option value=\"ar\">Arabic</option>\n                    </select>\n                </div>\n            </div>\n    \n        </div>\n    </footer>\n\n    <script src=\"js/site.js\"></script>\n    <script src=\"js/messages.js\"></script> \n        \n    <script type=\"text/javascript\">\n\n        CountryCode = \"\";\n        CityCode = \"\";\n        DistrictCode = \"\";\n        BaseUrl = \"https://api.suleymaniyetakvimi.com/api\"\n\n        $(document).ready(function () {\n\n            var queryString = window.location.search;\n            var urlParams = new URLSearchParams(queryString);\n            Language = urlParams.get('lang') || \"tr\";\n            ImageName = \"imsakiye.jpg\";\n            displayTextByLanguage();\n            getCountryList();\n            $(\"#ddlLanguage\").val(Language);\n\n            $(\"#ddlLanguage\").change(function() {\n                Language = $(this).val();\n                window.location.href = \"index.html?lang=\" + Language;\n            });\n\n            $(\"#ddlCountry\").on(\"change\", function () {\n            \n                $(\"#ddlCity\").empty();\n                CityCode = \"\";\n                $(\"#ddlDistrict\").empty();\n                DistrictCode = \"\";\n\n                $(\"#divImsakiye\").html(\"\");\n                $(\"#aImsakiye\").hide();\n                $(\"#aImsakiye\").attr(\"href\", \"#\");\n                    \n\n                if(this.value != \"\" && this.value != \"-1\"){\n                    CountryCode = this.value;\n                    var prm = \"?countryCode=\" + CountryCode;\n                    getContent(\"/Location/CityList\", prm, function(result) {\n                        $(\"#ddlCity\").empty();\n                        $(\"#ddlCity\").append($('<option></option>').val(\"-1\").html(GetMessage('seciniz', Language)));\n                        $.each(result, function (i, p) {\n                            $(\"#ddlCity\").append($('<option></option>').val(p.code).html(p.name));\n                        });\n                    });\n                }\n            });\n\n            $(\"#ddlCity\").on(\"change\",function () {\n                \n                $(\"#ddlDistrict\").empty();\n                if(this.value != \"\" && this.value != \"-1\"){\n                    CityCode = this.value;\n                    if(CountryCode == \"TR\"){\n                        var prm = \"?cityCode=\" + CityCode;\n                        getContent(\"/Location/DistrictList\", prm, function(result) {\n                            $(\"#ddlDistrict\").empty();\n                            $(\"#ddlDistrict\").append($('<option></option>').val(\"-1\").html(GetMessage('seciniz', Language)));\n                            $.each(result, function (i, p) {\n                                $(\"#ddlDistrict\").append($('<option></option>').val(p.code).html(p.name));\n                            });\n                        });\n                    }\n                }\n            });\n\n            $(\"#ddlDistrict\").on(\"change\", function () {\n                if(this.value != \"\" && this.value != \"-1\"){\n                    DistrictCode = this.value;\n                }\n            });\n\n            $(\"#btnSearchLocation\").click(function (e) {\n                e.preventDefault();\n                if(CountryCode && CityCode)\n                {\n                    url = BaseUrl + \"/TimeCalculation/Imsakiye?countryCode=\" + CountryCode +\"&cityCode=\" + CityCode +\"&districtCode=\" + DistrictCode;\n\n                    if(DistrictCode != \"\"){\n                        ImageName =  $(\"#ddlCountry option:selected\").text() + \"_\" + $(\"#ddlCity option:selected\").text() + \"_\" +  $(\"#ddlDistrict option:selected\").text() + \".jpg\";\n                    }\n                    else\n                    {\n                        ImageName =  $(\"#ddlCountry option:selected\").text() + \"_\" + $(\"#ddlCity option:selected\").text() + \".jpg\";\n                    }\n\n                    var xhr = new XMLHttpRequest();\n                    xhr.responseType = 'blob';\n                    xhr.open('GET', url);\n\n                    // On successful load\n                    xhr.onload = function() {\n                        if (xhr.status === 200) {\n                            var blob = new Blob([xhr.response], { type: 'image/png' });\n\n                            $(\"#aImsakiye\").attr('download', ImageName);\n                            $(\"#aImsakiye\").attr('href', window.URL.createObjectURL(blob));\n                            $(\"#divImsakiye\").html(\"<img id='imgImsakiye' src='\"+ window.URL.createObjectURL(blob)+\"' />\")\n                            $(\"#aImsakiye\").show(); \n                        }\n                    };\n                    xhr.send();\n                    \n                }\n                else{\n                    $(\"#divImsakiye\").html(\"\");\n                    $(\"#aImsakiye\").hide();\n                }\n\n            });\n\n\n        });\n\n        function getCountryList() {\n            getContent(\"/Location/CountryList\", \"\", function(result) {\n                $(\"#ddlCountry\").empty();\n                $(\"#ddlCountry\").append($('<option></option>').val(\"-1\").html(GetMessage('seciniz', Language)));\n                $.each(result, function (i, p) {\n                    $(\"#ddlCountry\").append($('<option></option>').val(p.code).html(p.name));\n                });\n                \n                $(\"#ddlCountry\").val(\"TR\");\n                $(\"#ddlCountry\").trigger(\"change\");\n            });\n        }\n\n        function getContent(method, parameter, callback) {\n\n            $.ajax({\n                method: 'GET',\n                cache: false,\n                url: BaseUrl  + method + parameter,\n                success: function (result,status,xhr) {\n                    if(callback){\n                        callback(result);\n                    }\n                },\n                error: function (xhr, status, error) {\n                    console.log(\"Result: \" + status + \" \" + error + \" \" + xhr.status + \" \" + xhr.statusText)\n                },\n                failure: function (result) {\n                    console.log(result.responseText);\n                }\n            });\n        } \n\n        function displayTextByLanguage() {\n            $(\"#ddlLanguage\").val(Language);\n            $(\"#headerText\").html(GetMessage('titleimsakiye', Language));\n            $(\"#countryArea\").html(GetMessage('ulke', Language));\n            $(\"#cityArea\").html(GetMessage('il', Language));\n            $(\"#districtArea\").html(GetMessage('ilce', Language));\n            $(\"#searchText\").html(GetMessage('imsakiyegoster', Language));\n            $(\"#downloadText\").html(GetMessage('imsakiyeindir', Language));\n        }\n\n    </script>\n\n<script defer=\"\" src=\"https://static.cloudflareinsights.com/beacon.min.js/v833ccba57c9e4d2798f2e76cebdd09a11778172276447\" integrity=\"sha512-57MDmcccJXYtNnH+ZiBwzC4jb2rvgVCEokYN+L/nLlmO8rfYT/gIpW2A569iJ/3b+0UEasghjuZH/ma3wIs/EQ==\" data-cf-beacon=\"{&quot;version&quot;:&quot;2024.11.0&quot;,&quot;token&quot;:&quot;63f1d9e51d9249c786bb12f74c404ea2&quot;,&quot;r&quot;:1,&quot;server_timing&quot;:{&quot;name&quot;:{&quot;cfCacheStatus&quot;:true,&quot;cfEdge&quot;:true,&quot;cfExtPri&quot;:true,&quot;cfL4&quot;:true,&quot;cfOrigin&quot;:true,&quot;cfSpeedBrain&quot;:true},&quot;location_startswith&quot;:null}}\" crossorigin=\"anonymous\"></script>\n\n\n</body></html>",
